# ============================================================
#  小研 (XiaoYan) 环境变量配置模板
# ============================================================
#  复制本文件为 .env 并填入真实值:
#    cp .env.example .env
#
#  也可通过交互式引导自动生成:
#    xiaoyan init
# ============================================================

# --- LLM (OpenAI 兼容 API) ---
XIAOYAN_LLM_API_KEY=sk-your-api-key-here
XIAOYAN_LLM_BASE_URL=https://api.openai.com/v1
XIAOYAN_LLM_MODEL=gpt-4o-mini

# --- 飞书 ---
# 你的飞书机器人所在的聊天 ID (可通过 lark-cli im chats list 查询)
XIAOYAN_LARK_CHAT_ID=oc_your_chat_id_here

# --- 数据存储 ---
# 小研数据目录 (默认 ~/.xiaoyan/)
# XIAOYAN_DATA_DIR=~/.xiaoyan

# Scraper 专属数据目录 (默认 ~/.xiaoyan/scraper/)
# XIAOYAN_SCRAPER_DATA_DIR=~/.xiaoyan/scraper

# --- 定时调度 ---
# 默认爬取间隔 (cron 表达式，默认每 6 小时)
XIAOYAN_DEFAULT_CRON="0 */6 * * *"

# --- 飞书多维表格 (P1-1, 首次运行自动创建并写入) ---
# XIAOYAN_BASE_TOKEN=
# XIAOYAN_BASE_TABLE_ID=
